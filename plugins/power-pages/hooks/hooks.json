{
  "description": "Centralized Power Pages lifecycle hooks",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/run-skill-posttool-validation.js\"",
            "timeout": 30,
            "statusMessage": "Running Power Pages validator"
          }
        ]
      }
    ]
  }
}
